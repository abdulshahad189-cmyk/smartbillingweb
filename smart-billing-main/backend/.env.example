# Smart Billing Backend Configuration

# Server
PORT=5000
NODE_ENV=development

# Email (for receipt sending)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=support@smartbilling.com

# Database (when implementing)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smartbilling
DB_USER=postgres
DB_PASSWORD=password

# API
API_SECRET=your-secret-key
JWT_SECRET=your-jwt-secret

# File Upload
MAX_FILE_SIZE=10MB
UPLOAD_DIR=./uploads

# CORS
CORS_ORIGIN=http://localhost:8000
